# Appwrite — skopiuj do .env i uzupełnij (w konsoli Appwrite: Project > Settings)
VITE_APPWRITE_ENDPOINT="https://fra.cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID="69b6d7d70034b41b8dbc"

# Baza rezerwacji: utwórz Database, potem Collection "reservations" z atrybutami:
# name (string, 200), email (string, 255), phone (string, 50), course (string, 100),
# preferredDate (string, 20), message (string, 2000), userId (string, 100, optional).
# Uprawnienia: Create dla "users" (Anyone).
VITE_APPWRITE_DATABASE_ID="69b6d873002732f9d529"
VITE_APPWRITE_RESERVATIONS_COLLECTION_ID="reservations"
